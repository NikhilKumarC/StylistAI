# Application Settings
APP_NAME=StylistAI
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Firebase Authentication
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Database
DATABASE_URL=sqlite:///./stylistai.db
# For PostgreSQL: postgresql://user:password@localhost/stylistai

# ChromaDB (Vector Database)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=outfits

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_CREDENTIALS_PATH=/path/to/your/credentials.json
GCS_PROJECT_ID=your-project-id

# OpenAI API (for embeddings and LLM)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4-turbo-preview

# Image Processing
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp

# CORS Settings (comma-separated list)
# Local development:
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# Production example:
# CORS_ORIGINS=https://stylistai.com,https://app.stylistai.com,https://www.stylistai.com
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=False
